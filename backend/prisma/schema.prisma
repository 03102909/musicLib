generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model albums {
  id            Int             @id @default(autoincrement())
  title         String          @db.VarChar(255)
  release_year  Int
  description   String?
  cover_url     String?         @db.VarChar(255)
  artist_id     Int
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  artists       artists         @relation(fields: [artist_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_albums_artist")
  albums_genres albums_genres[]
  library_item  library_item[]
}

model albums_genres {
  album_id Int
  genre_id Int
  albums   albums @relation(fields: [album_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ag_album")
  genres   genres @relation(fields: [genre_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ag_genre")

  @@id([album_id, genre_id])
}

model artists {
  id     Int      @id @default(autoincrement())
  name   String   @db.VarChar(255)
  albums albums[]
}

model genres {
  id            Int             @id @default(autoincrement())
  name          String          @unique @db.VarChar(100)
  albums_genres albums_genres[]
}

model library_item {
  id       Int       @id @default(autoincrement())
  user_id  Int
  album_id Int
  rating   Int?
  added_at DateTime? @default(now()) @db.Timestamp(6)
  albums   albums    @relation(fields: [album_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_li_album")
  users    users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_li_user")

  @@unique([user_id, album_id], map: "unique_user_album")
}

model users {
  id            Int            @id @default(autoincrement())
  email         String         @unique @db.VarChar(255)
  password_hash String         @db.VarChar(255)
  role          String?        @db.VarChar(50)
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  library_item  library_item[]
}
